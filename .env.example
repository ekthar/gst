# Environment configuration for GST HSN Resolver
# Copy to .env and customize if needed

# Python path - add src directory
PYTHONPATH=./src

# Server configuration
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_RUN_ON_SAVE=true
STREAMLIT_LOGGER_LEVEL=info

# Database
DATABASE_PATH=data/db/gst_hsn.db

# Google search
GOOGLE_SEARCH_DELAY=0.3
GOOGLE_SEARCH_TIMEOUT=10

# Performance
SIMILARITY_THRESHOLD=80
MAX_LOOKUP_RESULTS=10
